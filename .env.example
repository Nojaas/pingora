# App
NODE_ENV=development
PORT=3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pingora

# Redis
REDIS_URL=redis://localhost:6379

# Auth interne (pour créer des clés admin au seed)
ADMIN_SECRET=change_me_in_prod

# Email (Resend en prod, nodemailer + Mailpit en dev)
EMAIL_PROVIDER=nodemailer
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=pingora@localhost
RESEND_API_KEY=

# SMS (Twilio — utilise un mock en dev)
SMS_PROVIDER=mock
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# AWS / LocalStack
AWS_ENDPOINT=http://localhost:4566
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
